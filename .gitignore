# ============================================================
# Agent Harness — .gitignore
# ============================================================

# Environment / Secrets
.env
!.env.example
*.pem
*.key
secrets.json

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.venv/
venv/
env/
ENV/
*.egg-info/
dist/
build/
.eggs/
.pytest_cache/
.mypy_cache/
.ruff_cache/
htmlcov/
.coverage
coverage.xml

# Node / Frontend
node_modules/
frontend/dist/
.npm
*.tgz
.parcel-cache
.vite/

# Data (persisted volumes — don't commit runtime data)
data/db/*.db
data/chroma/
data/workspace/
data/projects/
# Keep default personality templates
!data/personality/
!data/personality/*.md

# Logs
*.log
logs/

# IDE
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# Docker
.dockerignore

# OS
.DS_Store
.DS_Store?
._*
.Spotlight-V7
.Trashes
ehthumbs.db
