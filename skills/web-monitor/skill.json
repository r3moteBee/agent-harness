{
  "name": "web-monitor",
  "version": "1.0.0",
  "description": "Monitor a web page for changes and report differences",
  "author": "community-contrib",
  "license": "MIT",
  "triggers": [
    "monitor a website",
    "check if a page has changed",
    "watch a URL for updates"
  ],
  "parameters": [
    { "name": "url", "type": "string", "required": true, "description": "URL to monitor" },
    { "name": "interval", "type": "integer", "required": false, "description": "Check interval in minutes" }
  ],
  "capabilities_required": ["file_read"],
  "dependencies": { "python": ["requests", "difflib"] },
  "tags": ["web", "monitoring", "utility"]
}
